---
# Site search — Pagefind indexes _site/ after Eleventy; UI assets live at /pagefind/ (generated at build).
permalink: /search/index.html
---
<!DOCTYPE html>
<html lang="en" data-pagefind-ignore>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Search | ReliaDB</title>
  <meta name="description" content="Search ReliaDB articles and pages for PostgreSQL, MySQL, and database consulting topics." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="../css/style.css" />
  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
  <style>
    /* Pagefind UI — brand alignment (navy #1A5276, accent #2980B9) */
    :root {
      --pagefind-ui-scale: 1;
      --pagefind-ui-primary: #1A5276;
      --pagefind-ui-text: #444444;
      --pagefind-ui-background: #ffffff;
      --pagefind-ui-border: #DDE3E9;
      --pagefind-ui-tag: #2980B9;
    }
    .search-page-hero {
      background: linear-gradient(135deg, #1A5276 0%, #154360 100%);
      padding: 140px 0 48px;
      color: #fff;
      text-align: center;
    }
    .search-page-hero h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); margin-bottom: 0.5rem; color: #fff; }
    .search-page-hero p { font-size: 1.05rem; color: rgba(255, 255, 255, 0.88); max-width: 560px; margin: 0 auto; }
    .search-page-main {
      max-width: 720px;
      margin: 0 auto;
      padding: 40px 24px 88px;
    }
    /* Larger tap targets on small screens; scrollable results */
    #search .pagefind-ui__search-input { font-size: 1.05rem !important; min-height: 48px; }
    #search .pagefind-ui__results-area { max-height: min(70vh, 560px); overflow-y: auto; }
  </style>
</head>
<body>
  <nav id="navbar" role="navigation" aria-label="Main navigation">
    <div class="nav-inner">
      <a href="../index.html" class="nav-logo" aria-label="ReliaDB Home">
        <div class="nav-logo-icon">R</div>
        <span class="nav-logo-text">Relia<span>DB</span></span>
      </a>
      <ul class="nav-links" id="navLinks">
        <li><a href="../index.html">Home</a></li>
        <li><a href="../services.html">Services</a></li>
        <li><a href="../results.html">Results</a></li>
        <li><a href="../blog/index.html">Blog</a></li>
        <li><a href="../about.html">About</a></li>
        <li><a href="../contact.html" class="nav-cta">Book Free Assessment</a></li>
      </ul>
      {% include "nav-search-controls.njk" %}
      <button id="navToggle" class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>

  <header class="search-page-hero">
    <div class="container">
      <h1>Search the site</h1>
      <p>Find blog posts and pages by keyword. Results load in your browser — no third-party search service.</p>
    </div>
  </header>

  <main class="search-page-main" id="main-content">
    <div id="search" role="search" aria-label="Site search"></div>
    <noscript>
      <p class="text-muted" style="margin-top: 1rem;">JavaScript is required for search. Browse the <a href="../blog/index.html">blog</a> or <a href="../services.html">services</a> instead.</p>
    </noscript>
  </main>

  {% include "footer.njk" %}

  <script src="../js/main.js"></script>
  <script type="module">
    /**
     * Pagefind: static search index built at `npm run build` (runs after Eleventy).
     * Loaded only on this page — keeps other routes free of the search bundle (~lazy load).
     */
    try {
      await import("/pagefind/pagefind-ui.js");
      const UI = window.PagefindUI;
      if (typeof UI === "function") {
        const q = new URLSearchParams(window.location.search).get("q");
        const ui = new UI({
          element: "#search",
          showSubResults: true,
          showImages: false,
          excerptLength: 22,
          resetStyles: false
        });
        if (q && q.trim()) ui.triggerSearch(q.trim());
      }
    } catch (e) {
      const el = document.getElementById("search");
      if (el) {
        el.innerHTML =
          '<p role="alert" style="padding:1rem;background:#fff3cd;border-radius:8px;color:#856404">Search index is not available. Run <code>npm run build</code> locally (which runs Pagefind after Eleventy), then open the built site from <code>_site/</code>.</p>';
      }
      console.warn("Pagefind UI failed to load:", e);
    }
  </script>
</body>
</html>
