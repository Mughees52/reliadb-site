---
permalink: /blog/index.html
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Blog | ReliaDB — PostgreSQL & MySQL Database Consulting</title>
  <meta name="description" content="Practical guides, case studies, and deep-dives on PostgreSQL performance, MySQL optimisation, AWS RDS, high availability, and database best practices." />
  <link rel="canonical" href="https://reliadb.com/blog/index.html" />

  <!-- Open Graph -->
  <meta property="og:title" content="Blog | ReliaDB — PostgreSQL & MySQL Database Consulting" />
  <meta property="og:description" content="Practical guides, case studies, and deep-dives on PostgreSQL performance, MySQL optimisation, AWS RDS, high availability, and database best practices." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://reliadb.com/blog/index.html" />
  <meta property="og:image" content="https://reliadb.com/images/og-default.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />

  <!-- Fonts (non-blocking) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" onload="this.onload=null;this.rel='stylesheet'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" /></noscript>
  <link rel="preload" href="/images/ReliaDB logo.svg" as="image" fetchpriority="high" />
  <link rel="stylesheet" href="../css/style.css" />
  <link rel="apple-touch-icon" href="/images/ReliaDB-Logo.png">
  <link rel="icon" type="image/png" href="/images/ReliaDB-Logo.png">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%231A5276'/><text y='.9em' font-size='70' x='12' fill='white' font-weight='800'>R</text></svg>">
  <style>
    /* ── Hero (compact) ── */
    .blog-hero {
      background: linear-gradient(135deg, #1A5276 0%, #154360 100%);
      padding: 100px 0 32px;
      color: #fff;
    }
    .blog-hero-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 24px;
      flex-wrap: wrap;
    }
    .blog-hero h1 {
      font-size: clamp(1.8rem, 3.5vw, 2.6rem);
      font-weight: 800;
      color: #fff;
      margin: 0;
    }
    .blog-hero p {
      font-size: 1rem;
      color: rgba(255,255,255,0.7);
      margin: 6px 0 0;
    }
    .blog-hero-stats {
      display: flex;
      gap: 24px;
    }
    .blog-hero-stat {
      text-align: center;
    }
    .blog-hero-stat strong {
      display: block;
      font-size: 1.5rem;
      font-weight: 800;
      color: #fff;
    }
    .blog-hero-stat span {
      font-size: 0.75rem;
      color: rgba(255,255,255,0.6);
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    /* ── Category filter bar ── */
    .cat-bar {
      max-width: 1200px;
      margin: 0 auto;
      padding: 20px 24px 0;
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }
    .cat-pill {
      background: #f0f4f8;
      color: #555;
      font-size: 0.8rem;
      font-weight: 600;
      padding: 6px 14px;
      border-radius: 20px;
      text-decoration: none;
      transition: background .18s, color .18s;
      border: 1px solid transparent;
    }
    .cat-pill:hover, .cat-pill.active {
      background: #1A5276;
      color: #fff;
    }

    /* ── Featured post (first post, full width) ── */
    .featured-post {
      max-width: 1200px;
      margin: 24px auto 0;
      padding: 0 24px;
    }
    .featured-card {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0;
      background: #fff;
      border: 1px solid #e5e7eb;
      border-radius: 14px;
      overflow: hidden;
      text-decoration: none;
      transition: box-shadow .24s, transform .2s;
    }
    .featured-card:hover {
      box-shadow: 0 16px 40px rgba(26,82,118,0.12);
      transform: translateY(-2px);
    }
    .featured-left {
      background: linear-gradient(135deg, #1A5276, #2980B9);
      padding: 40px 36px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      position: relative;
      overflow: hidden;
    }
    .featured-left::after {
      content: "";
      position: absolute;
      right: -40px;
      top: -40px;
      width: 160px;
      height: 160px;
      border-radius: 50%;
      background: rgba(255,255,255,0.04);
    }
    .featured-badge {
      background: #E67E22;
      color: #fff;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 4px 10px;
      border-radius: 4px;
      width: fit-content;
      margin-bottom: 16px;
    }
    .featured-left h2 {
      font-size: 1.5rem;
      font-weight: 800;
      color: #fff;
      line-height: 1.35;
      margin: 0 0 12px;
    }
    .featured-left .feat-desc {
      font-size: 0.92rem;
      color: rgba(255,255,255,0.8);
      line-height: 1.7;
      margin: 0;
    }
    .featured-left .feat-read {
      margin-top: 20px;
      font-size: 0.88rem;
      font-weight: 600;
      color: #E67E22;
    }
    .featured-right {
      padding: 36px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .featured-right .feat-meta {
      display: flex;
      gap: 8px;
      align-items: center;
      flex-wrap: wrap;
      margin-bottom: 10px;
    }
    .featured-right .feat-cat {
      background: #EAF2F8;
      color: #1A5276;
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      padding: 3px 9px;
      border-radius: 12px;
    }
    .featured-right .feat-date {
      font-size: 0.8rem;
      color: #999;
    }
    .featured-right h3 {
      font-size: 1.1rem;
      color: #1a1a2e;
      font-weight: 700;
      line-height: 1.4;
      margin: 0 0 8px;
    }
    .featured-right p {
      font-size: 0.88rem;
      color: #666;
      line-height: 1.65;
      margin: 0;
    }

    /* ── Post grid ── */
    .blog-grid-section {
      max-width: 1200px;
      margin: 32px auto 0;
      padding: 0 24px 64px;
    }
    .blog-grid-section h2 {
      font-size: 1.1rem;
      font-weight: 700;
      color: #1a1a2e;
      margin-bottom: 20px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .post-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    .post-card {
      background: #fff;
      border: 1px solid #e5e7eb;
      border-radius: 12px;
      padding: 24px;
      text-decoration: none;
      display: flex;
      flex-direction: column;
      transition: box-shadow .24s, transform .2s, border-color .2s;
      position: relative;
    }
    .post-card::before {
      content: "";
      position: absolute;
      left: 0;
      top: 0;
      height: 3px;
      width: 100%;
      background: linear-gradient(90deg, #1A5276, #2980B9);
      border-radius: 12px 12px 0 0;
      opacity: 0;
      transition: opacity .2s;
    }
    .post-card:hover {
      box-shadow: 0 12px 30px rgba(26,82,118,0.1);
      transform: translateY(-3px);
      border-color: #d3e1ef;
    }
    .post-card:hover::before { opacity: 1; }
    .post-card .pc-meta {
      display: flex;
      gap: 6px;
      align-items: center;
      flex-wrap: wrap;
      margin-bottom: 10px;
    }
    .post-card .pc-cat {
      background: #EAF2F8;
      color: #1A5276;
      font-size: 0.68rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      padding: 2px 8px;
      border-radius: 10px;
    }
    .post-card .pc-date {
      font-size: 0.78rem;
      color: #aaa;
    }
    .post-card h3 {
      font-size: 1.02rem;
      font-weight: 700;
      color: #1a1a2e;
      line-height: 1.4;
      margin: 0 0 8px;
      flex-grow: 1;
    }
    .post-card .pc-desc {
      font-size: 0.85rem;
      color: #777;
      line-height: 1.6;
      margin: 0 0 14px;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .post-card .pc-footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: auto;
      padding-top: 14px;
      border-top: 1px solid #f0f0f0;
    }
    .post-card .pc-read {
      font-size: 0.82rem;
      font-weight: 600;
      color: #2980B9;
    }
    .post-card .pc-time {
      font-size: 0.76rem;
      color: #bbb;
    }

    /* ── Sidebar CTA at bottom on mobile ── */
    .blog-bottom-cta {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px 64px;
    }
    .bottom-cta-card {
      background: #1A5276;
      border-radius: 14px;
      padding: 40px;
      text-align: center;
      color: #fff;
    }
    .bottom-cta-card h2 {
      font-size: 1.5rem;
      font-weight: 800;
      color: #fff;
      margin-bottom: 10px;
    }
    .bottom-cta-card p {
      font-size: 1rem;
      color: rgba(255,255,255,0.8);
      margin-bottom: 20px;
      max-width: 500px;
      margin-left: auto;
      margin-right: auto;
    }
    .bottom-cta-card .btn {
      background: #E67E22;
      border-color: #E67E22;
      color: #fff;
      padding: 12px 28px;
      border-radius: 8px;
      font-weight: 600;
      font-size: 1rem;
      text-decoration: none;
      display: inline-block;
    }

    /* ── Responsive ── */
    @media (max-width: 900px) {
      .featured-card { grid-template-columns: 1fr; }
      .post-grid { grid-template-columns: 1fr 1fr; }
      .blog-hero-stats { display: none; }
    }
    @media (max-width: 600px) {
      .post-grid { grid-template-columns: 1fr; }
      .featured-left { padding: 28px 24px; }
      .featured-right { padding: 24px; }
    }
  </style>
</head>
<body>
  <nav id="navbar">
    <div class="nav-inner">
      <a href="../index.html" class="nav-logo" aria-label="ReliaDB Home">
        <img src="/images/ReliaDB logo.svg" alt="ReliaDB logo" class="nav-logo-image" width="180" height="42" />
        <span class="nav-logo-text">Relia<span>DB</span></span>
      </a>
      <ul class="nav-links" id="navLinks">
        <li><a href="../index.html">Home</a></li>
        <li><a href="../services.html">Services</a></li>
        <li><a href="../results.html">Results</a></li>
        <li><a href="index.html" class="active">Blog</a></li>
        <li><a href="../about.html">About</a></li>
        <li><a href="../contact.html" class="nav-cta">Book Free Assessment</a></li>
      </ul>
      {% include "nav-search-controls.njk" %}
      <button id="navToggle" class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false"><span></span><span></span><span></span></button>
    </div>
  </nav>

  <!-- ── Compact Hero ── -->
  <section class="blog-hero">
    <div class="blog-hero-inner">
      <div>
        <h1>The ReliaDB Blog</h1>
        <p>PostgreSQL &amp; MySQL guides from production experience</p>
      </div>
      <div class="blog-hero-stats">
        <div class="blog-hero-stat">
          <strong>{{ collections.blogPosts.length }}</strong>
          <span>Articles</span>
        </div>
        <div class="blog-hero-stat">
          <strong>{{ collections.categories.length }}</strong>
          <span>Topics</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Category Filter ── -->
  <div class="cat-bar">
    <a href="/blog/index.html" class="cat-pill active">All</a>
    {% for cat in collections.categories %}
      <a href="/blog/category/{{ cat.slug }}/" class="cat-pill">{{ cat.title }}</a>
    {% endfor %}
  </div>

  <!-- ── Featured Post (latest) ── -->
  {% set latest = collections.blogPosts[0] %}
  {% set latestCats = latest.data | postCategories(collections.categories) %}
  {% set second = collections.blogPosts[1] %}
  {% set secondCats = second.data | postCategories(collections.categories) %}
  <div class="featured-post">
    <a href="{{ latest.url }}" class="featured-card">
      <div class="featured-left">
        <div class="featured-badge">Latest Post</div>
        <h2>{{ latest.data.title }}</h2>
        <p class="feat-desc">{{ latest.data.description }}</p>
        <span class="feat-read">Read article &rarr;</span>
      </div>
      <div class="featured-right">
        <div class="feat-meta">
          {% for cat in latestCats %}
            <span class="feat-cat">{{ cat.title }}</span>
          {% endfor %}
          <span class="feat-date">{{ latest.date.toDateString() }} &middot; {{ latest.data.read_time or 8 }} min</span>
        </div>
        <h3>Up Next</h3>
        <div class="feat-meta" style="margin-top:16px">
          {% for cat in secondCats %}
            <span class="feat-cat">{{ cat.title }}</span>
          {% endfor %}
          <span class="feat-date">{{ second.date.toDateString() }}</span>
        </div>
        <h3 style="margin-top:4px"><a href="{{ second.url }}" style="color:#1a1a2e;text-decoration:none;">{{ second.data.title }}</a></h3>
        <p>{{ second.data.description | truncate(120) }}</p>
      </div>
    </a>
  </div>

  <!-- ── All Posts Grid ── -->
  <div class="blog-grid-section">
    <h2>All Articles</h2>
    <div class="post-grid">
      {% for post in collections.blogPosts %}
        {% if loop.index > 2 %}
          {% set cats = post.data | postCategories(collections.categories) %}
          <a href="{{ post.url }}" class="post-card">
            <div class="pc-meta">
              {% for cat in cats %}
                <span class="pc-cat">{{ cat.title }}</span>
              {% endfor %}
              <span class="pc-date">{{ post.date.toDateString() }}</span>
            </div>
            <h3>{{ post.data.title }}</h3>
            <p class="pc-desc">{{ post.data.description }}</p>
            <div class="pc-footer">
              <span class="pc-read">Read &rarr;</span>
              <span class="pc-time">{{ post.data.read_time or 8 }} min</span>
            </div>
          </a>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <!-- ── Bottom CTA ── -->
  <div class="blog-bottom-cta">
    <div class="bottom-cta-card">
      <h2>Need help with your database?</h2>
      <p>Book a free 30-minute assessment call and get actionable recommendations for your setup.</p>
      <a href="../contact.html" class="btn">Book Free Assessment &rarr;</a>
    </div>
  </div>

  {% include "footer.njk" %}
  <script src="../js/main.js"></script>
</body>
</html>
