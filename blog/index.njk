permalink: /blog/index.html
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Blog | ReliaDB — PostgreSQL & MySQL Database Consulting</title>
  <meta name="description" content="Practical guides, case studies, and deep-dives on PostgreSQL performance, MySQL optimisation, AWS RDS, high availability, and database best practices." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="../css/style.css" />
  <style>
    .blog-hero { background: linear-gradient(135deg, #1A5276 0%, #154360 100%); padding: 140px 0 80px; text-align: center; color: #fff; }
    .blog-hero h1 { font-size: clamp(2rem, 4vw, 3rem); margin-bottom: 1rem; color: #ffffff; font-weight: 800; }
    .blog-hero p { font-size: 1.15rem; color: rgba(255,255,255,0.85); max-width: 600px; margin: 0 auto; }
    .blog-hero h1,
    .blog-hero p { animation: fadeUp .6s ease both; }
    .blog-hero p { animation-delay: .12s; }
    .blog-main { max-width: 1100px; margin: 0 auto; padding: 64px 24px; display: grid; grid-template-columns: 1fr 320px; gap: 56px; align-items: start; }
    .post-list { display: flex; flex-direction: column; gap: 32px; }
    .post-card-h { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 28px 32px; transition: box-shadow 0.24s, transform 0.2s, border-color 0.2s; text-decoration: none; display: block; position: relative; overflow: hidden; }
    .post-card-h::before { content: ""; position: absolute; left: 0; top: 0; height: 3px; width: 100%; background: linear-gradient(90deg, #1A5276, #2980B9); opacity: 0; transition: opacity 0.2s ease; }
    .post-card-h:hover { box-shadow: 0 14px 34px rgba(26,82,118,0.14); transform: translateY(-3px); border-color: #d3e1ef; }
    .post-card-h:hover::before { opacity: 1; }
    .post-meta { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; flex-wrap: wrap; }
    .post-cat { background: #EAF2F8; color: #1A5276; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.07em; text-transform: uppercase; padding: 3px 9px; border-radius: 20px; }
    .post-date, .post-read-time { font-size: 0.82rem; color: #999; }
    .post-card-h h2 { font-size: 1.2rem; color: #1a1a2e; margin-bottom: 10px; line-height: 1.4; font-weight: 700; }
    .post-card-h p { font-size: 0.93rem; color: #666; line-height: 1.7; margin: 0; }
    .post-read-more { display: inline-flex; align-items: center; gap: 4px; font-size: 0.85rem; font-weight: 600; color: #2980B9; margin-top: 14px; transition: transform .18s ease, color .18s ease; }
    .post-card-h:hover .post-read-more { transform: translateX(2px); color: #1A5276; }
    .blog-sidebar { position: sticky; top: 90px; }
    .sidebar-widget { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 24px; margin-bottom: 24px; transition: transform .2s ease, box-shadow .24s ease, border-color .2s ease; }
    .sidebar-widget:hover { transform: translateY(-2px); box-shadow: 0 12px 22px rgba(26,82,118,0.1); border-color: #d6e2ef; }
    .sidebar-widget h3 { font-size: 0.9rem; font-weight: 700; color: #1a1a2e; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 16px; padding-bottom: 12px; border-bottom: 2px solid #EAF2F8; }
    .sidebar-links { list-style: none; padding: 0; margin: 0; }
    .sidebar-links li { padding: 8px 0; border-bottom: 1px solid #f0f0f0; }
    .sidebar-links a { font-size: 0.9rem; color: #444; text-decoration: none; line-height: 1.4; transition: color .18s ease, padding-left .18s ease; }
    .sidebar-links a:hover { color: #1A5276; padding-left: 3px; }
    .sidebar-cta { background: #1A5276; color: #fff; border-radius: 12px; padding: 28px 24px; text-align: center; border: none; }
    .sidebar-cta h3 { color: #fff; border-bottom-color: rgba(255,255,255,0.2); }
    .sidebar-cta p { font-size: 0.88rem; color: rgba(255,255,255,0.8); line-height: 1.6; margin-bottom: 16px; }
    .sidebar-cta .btn { background: #E67E22; border-color: #E67E22; font-size: 0.88rem; padding: 10px 18px; }

    .reveal-on-scroll {
      opacity: 0;
      transform: translateY(22px);
      transition: opacity .55s ease, transform .55s cubic-bezier(.2,.65,.2,1);
      will-change: transform, opacity;
    }
    .reveal-on-scroll.is-visible {
      opacity: 1;
      transform: translateY(0);
    }
    .reveal-stagger-1 { transition-delay: .08s; }
    .reveal-stagger-2 { transition-delay: .16s; }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(14px); }
      to { opacity: 1; transform: translateY(0); }
    }

    @media (prefers-reduced-motion: reduce) {
      .blog-hero h1, .blog-hero p,
      .reveal-on-scroll,
      .post-card-h,
      .sidebar-widget,
      .post-read-more,
      .sidebar-links a {
        animation: none !important;
        transition: none !important;
        transform: none !important;
        opacity: 1 !important;
      }
    }
    @media (max-width: 880px) { .blog-main { grid-template-columns: 1fr; } .blog-sidebar { position: static; } }
  </style>
</head>
<body>
  <nav id="navbar">
    <div class="nav-inner">
      <a href="../index.html" class="nav-logo" aria-label="ReliaDB Home">
        <img src="/images/ReliaDB logo.svg" alt="ReliaDB logo" class="nav-logo-image" />
        <span class="nav-logo-text">Relia<span>DB</span></span>
      </a>
      <ul class="nav-links" id="navLinks">
        <li><a href="../index.html">Home</a></li>
        <li><a href="../services.html">Services</a></li>
        <li><a href="../results.html">Results</a></li>
        <li><a href="index.html" class="active">Blog</a></li>
        <li><a href="../about.html">About</a></li>
        <li><a href="../contact.html" class="nav-cta">Book Free Assessment</a></li>
      </ul>
      {% include "nav-search-controls.njk" %}
      <button id="navToggle" class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false"><span></span><span></span><span></span></button>
    </div>
  </nav>

  <section class="blog-hero">
    <div class="container">
      <h1>The ReliaDB Blog</h1>
      <p>Practical guides on PostgreSQL performance, MySQL optimisation, AWS RDS cost savings, high availability, and everything in between.</p>
    </div>
  </section>

  <div class="blog-main">
    <main>
      <div class="post-list">
        {% for post in collections.blogPosts %}
          <a href="{{ post.url }}" class="post-card-h">
            <div class="post-meta">
              {% set categories = post.data | postCategories(collections.categories) %}
              {% if categories.length %}
                {% for cat in categories %}
                  <span class="post-cat">{{ cat.title }}</span>
                {% endfor %}
              {% else %}
                <span class="post-cat">Uncategorized</span>
              {% endif %}
              <span class="post-date">{{ post.date.toDateString() }}</span>
              <span class="post-read-time">{{ post.data.read_time or 8 }} min read</span>
            </div>
            <h2>{{ post.data.title }}</h2>
            <p>{{ post.data.description }}</p>
            <span class="post-read-more">Read article &rarr;</span>
          </a>
        {% endfor %}
      </div>
    </main>

    <aside class="blog-sidebar">
      <div class="sidebar-widget sidebar-cta">
        <h3>Database Problems?</h3>
        <p>Book a free 30-minute assessment call and get actionable recommendations.</p>
        <a href="../contact.html" class="btn">Book Free Assessment</a>
      </div>

      <div class="sidebar-widget">
        <h3>Categories</h3>
        <ul class="sidebar-links">
          {% for cat in collections.categories %}
            <li><a href="/blog/category/{{ cat.slug }}/">{{ cat.title }} ({{ cat.posts.length }})</a></li>
          {% endfor %}
        </ul>
      </div>

      <div class="sidebar-widget">
        <h3>Latest Posts</h3>
        <ul class="sidebar-links">
          {% for post in collections.blogPosts %}
            {% if loop.index <= 6 %}
              <li><a href="{{ post.url }}">{{ post.data.title }}</a></li>
            {% endif %}
          {% endfor %}
        </ul>
      </div>
    </aside>
  </div>

  {% include "footer.njk" %}

  <script src="../js/main.js"></script>
  <script>
    (function () {
      const targets = [
        ...document.querySelectorAll('.post-card-h'),
        ...document.querySelectorAll('.sidebar-widget')
      ];

      targets.forEach((el, index) => {
        el.classList.add('reveal-on-scroll');
        if (index % 3 === 1) el.classList.add('reveal-stagger-1');
        if (index % 3 === 2) el.classList.add('reveal-stagger-2');
      });

      if (!('IntersectionObserver' in window)) {
        targets.forEach(el => el.classList.add('is-visible'));
        return;
      }

      const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            io.unobserve(entry.target);
          }
        });
      }, { rootMargin: '0px 0px -10% 0px', threshold: 0.12 });

      targets.forEach(el => io.observe(el));
    })();
  </script>
</body>
</html>
