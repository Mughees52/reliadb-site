<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }} | ReliaDB Blog</title>
  <meta name="description" content="{{ description }}" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="../css/style.css" />
  <style>
    .post-hero { background: linear-gradient(135deg, #1A5276 0%, #154360 100%); padding: 140px 0 60px; color: #fff; }
    .post-hero-inner { max-width: 760px; margin: 0 auto; padding: 0 24px; }
    .post-meta-top { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; margin-bottom: 20px; }
    .post-cat-badge { background: rgba(255,255,255,0.15); color: #fff; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.07em; text-transform: uppercase; padding: 4px 12px; border-radius: 20px; }
    .post-date-top, .post-read-top { font-size: 0.85rem; color: rgba(255,255,255,0.7); }
    .post-hero h1 { font-size: clamp(1.7rem, 3.5vw, 2.4rem); line-height: 1.3; margin-bottom: 20px; }
    .post-hero .excerpt { font-size: 1.05rem; color: rgba(255,255,255,0.85); line-height: 1.7; }
    .post-layout { max-width: 1100px; margin: 0 auto; padding: 64px 24px; display: grid; grid-template-columns: 1fr 300px; gap: 56px; align-items: start; }
    .post-body { max-width: 720px; }
    .post-body h2 { font-size: 1.5rem; color: #1a1a2e; margin: 40px 0 16px; line-height: 1.3; }
    .post-body h3 { font-size: 1.15rem; color: #1a1a2e; margin: 28px 0 12px; }
    .post-body p { color: #444; line-height: 1.8; margin-bottom: 18px; font-size: 1rem; }
    .post-body ul, .post-body ol { padding-left: 24px; margin-bottom: 18px; }
    .post-body li { color: #444; line-height: 1.7; margin-bottom: 6px; font-size: 1rem; }
    .post-body code { background: #f0f4f8; color: #1A5276; padding: 2px 6px; border-radius: 4px; font-size: 0.88em; font-family: "Courier New", monospace; }
    .post-body pre { background: #1a1a2e; color: #e8f4f8; padding: 20px 24px; border-radius: 10px; overflow-x: auto; margin-bottom: 24px; font-size: 0.88rem; line-height: 1.65; }
    .post-body pre code { background: none; color: inherit; padding: 0; }
    .post-body blockquote { border-left: 4px solid #2980B9; margin: 24px 0; padding: 12px 20px; background: #f0f7ff; border-radius: 0 8px 8px 0; color: #444; font-style: italic; }
    .author-box { display: flex; align-items: flex-start; gap: 16px; border: 1px solid #e5e7eb; border-radius: 12px; padding: 24px; margin-top: 48px; }
    .author-avatar { width: 56px; height: 56px; border-radius: 50%; background: #1A5276; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; font-weight: 800; color: #fff; flex-shrink: 0; }
    .author-info h4 { font-size: 1rem; color: #1a1a2e; margin-bottom: 4px; }
    .author-info p { font-size: 0.88rem; color: #666; line-height: 1.6; margin: 0; }
    .post-sidebar { position: sticky; top: 90px; }
    .sidebar-widget { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 22px; margin-bottom: 20px; }
    .sidebar-widget h3 { font-size: 0.85rem; font-weight: 700; color: #1a1a2e; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 14px; padding-bottom: 10px; border-bottom: 2px solid #EAF2F8; }
    .toc-list { list-style: none; padding: 0; margin: 0; }
    .toc-list li { padding: 6px 0; border-bottom: 1px solid #f5f5f5; }
    .toc-list li:last-child { border-bottom: none; }
    .toc-list a { font-size: 0.87rem; color: #555; text-decoration: none; }
    .sidebar-cta-box { background: #1A5276; color: #fff; border-radius: 12px; padding: 24px 22px; text-align: center; border: none; }
    .sidebar-cta-box h3 { color: #fff; border-bottom-color: rgba(255,255,255,0.15); }
    .sidebar-cta-box p { font-size: 0.85rem; color: rgba(255,255,255,0.8); line-height: 1.6; margin-bottom: 14px; }
    .sidebar-cta-box .btn { background: #E67E22; border-color: #E67E22; font-size: 0.85rem; padding: 10px 16px; }
    @media (max-width: 880px) { .post-layout { grid-template-columns: 1fr; } .post-sidebar { position: static; } }
  </style>
</head>
<body>
  <nav id="navbar">
    <div class="nav-inner">
      <a href="../index.html" class="nav-logo"><span class="logo-icon">R</span><span class="logo-text">ReliaDB</span></a>
      <button id="navToggle" class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false"><span></span><span></span><span></span></button>
      <ul class="nav-links" id="navLinks">
        <li><a href="../index.html">Home</a></li>
        <li><a href="../services.html">Services</a></li>
        <li><a href="../results.html">Results</a></li>
        <li><a href="index.html" class="active">Blog</a></li>
        <li><a href="../about.html">About</a></li>
        <li><a href="../contact.html" class="nav-cta">Book Free Assessment</a></li>
      </ul>
    </div>
  </nav>

  <section class="post-hero">
    <div class="post-hero-inner">
      <div class="post-meta-top">
        <span class="post-cat-badge">{{ category or "PostgreSQL" }}</span>
        <span class="post-date-top">{{ page.date.toDateString() }}</span>
        <span class="post-read-top">&middot; {{ read_time or 8 }} min read</span>
      </div>
      <h1>{{ title }}</h1>
      <p class="excerpt">{{ description }}</p>
    </div>
  </section>

  <div class="post-layout">
    <article class="post-body">
      {{ content | safe }}
      <div class="author-box">
        <div class="author-avatar">M</div>
        <div class="author-info">
          <h4>Mughees — ReliaDB</h4>
          <p>Senior DBA specialising in PostgreSQL and MySQL performance, high availability, and cloud database optimisation. <a href="../about.html" style="color:#2980B9;">More about me &rarr;</a></p>
        </div>
      </div>
    </article>

    <aside class="post-sidebar">
      <div class="sidebar-widget sidebar-cta-box">
        <h3>Database Problems?</h3>
        <p>Get actionable advice for your setup in a free assessment call.</p>
        <a href="../contact.html" class="btn">Book Free Call</a>
      </div>
      <div class="sidebar-widget">
        <h3>Latest Posts</h3>
        <ul class="toc-list">
          {% for post in collections.blogPosts | slice(0, 5) %}
            <li><a href="{{ post.url }}">{{ post.data.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
    </aside>
  </div>

  <footer class="site-footer">
    <div class="footer-inner">
      <div class="footer-brand">
        <div class="footer-logo"><span class="logo-icon">R</span><span class="logo-text">ReliaDB</span></div>
        <p>International PostgreSQL &amp; MySQL consulting for growing companies, with delivery based in Pakistan.</p>
      </div>
    </div>
    <div class="footer-bottom"><p>&copy; 2024 ReliaDB. All rights reserved.</p></div>
  </footer>
  <script src="../js/main.js"></script>
</body>
</html>
