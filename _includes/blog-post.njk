<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }} | ReliaDB Blog</title>
  <meta name="description" content="{{ description }}" />
  <link rel="canonical" href="https://reliadb.com{{ page.url }}" />

  <!-- Open Graph -->
  <meta property="og:title" content="{{ title }}" />
  <meta property="og:description" content="{{ description }}" />
  <meta property="og:type" content="article" />
  <meta property="og:url" content="https://reliadb.com{{ page.url }}" />
  <meta property="og:image" content="https://reliadb.com{{ coverImage or '/images/og-default.png' }}" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content="ReliaDB" />
  <meta property="article:published_time" content="{{ page.date | date("%Y-%m-%dT%H:%M:%S+00:00") }}" />
  <meta property="article:author" content="{{ author or 'Mughees Ahmed' }}" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ title }}" />
  <meta name="twitter:description" content="{{ description }}" />
  <meta name="twitter:image" content="https://reliadb.com/images/og-default.png" />

  <!-- Fonts (non-blocking) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" onload="this.onload=null;this.rel='stylesheet'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" /></noscript>
  <link rel="preload" href="/images/ReliaDB logo.svg" as="image" fetchpriority="high" />
  <link rel="stylesheet" href="../css/style.css" />
  <link rel="apple-touch-icon" href="/images/ReliaDB-Logo.png">
  <link rel="icon" type="image/png" href="/images/ReliaDB-Logo.png">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%231A5276'/><text y='.9em' font-size='70' x='12' fill='white' font-weight='800'>R</text></svg>">

  <!-- Article Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "{{ title }}",
    "description": "{{ description }}",
    "datePublished": "{{ page.date | date("%Y-%m-%dT%H:%M:%S+00:00") }}",
    "author": {
      "@type": "Person",
      "name": "{{ author or 'Mughees Ahmed' }}",
      "url": "https://reliadb.com/about.html"
    },
    "publisher": {
      "@type": "Organization",
      "name": "ReliaDB",
      "url": "https://reliadb.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://reliadb.com/images/ReliaDB-Logo.png"
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "https://reliadb.com{{ page.url }}"
    }
  }
  </script>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://reliadb.com/" },
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://reliadb.com/blog/index.html" },
      { "@type": "ListItem", "position": 3, "name": "{{ title }}", "item": "https://reliadb.com{{ page.url }}" }
    ]
  }
  </script>
  <style>
    .post-hero { background: linear-gradient(135deg, #1A5276 0%, #154360 100%); padding: 120px 0 36px; color: #fff; }
    .post-hero-inner { max-width: 800px; margin: 0 auto; padding: 0 24px; }
    .post-meta-top { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; margin-bottom: 16px; }
    .post-cat-badge { background: rgba(255,255,255,0.15); color: #fff; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.07em; text-transform: uppercase; padding: 4px 12px; border-radius: 20px; text-decoration: none; display: inline-block; }
    .post-date-top, .post-read-top { font-size: 0.82rem; color: rgba(255,255,255,0.65); }
    .post-hero h1 { font-size: clamp(1.7rem, 3.5vw, 2.4rem); line-height: 1.3; margin-bottom: 12px; color: #fff; }
    .post-hero .excerpt { font-size: 1rem; color: rgba(255,255,255,0.75); line-height: 1.7; margin-bottom: 0; }
    /* Cover image banner */
    .post-cover-banner { max-width: 900px; margin: -20px auto 0; padding: 0 24px; position: relative; z-index: 2; }
    .post-cover-card { border-radius: 16px; overflow: hidden; position: relative; box-shadow: 0 12px 40px rgba(0,0,0,0.2); }
    .post-cover-card img { width: 100%; height: 340px; object-fit: cover; display: block; }
    .post-cover-overlay { position: absolute; inset: 0; background: linear-gradient(0deg, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.1) 50%, rgba(0,0,0,0.05) 100%); }
    .post-cover-content { position: absolute; bottom: 0; left: 0; right: 0; padding: 28px 32px; display: flex; justify-content: space-between; align-items: flex-end; }
    .post-cover-title { font-size: 1.3rem; font-weight: 700; color: #fff; line-height: 1.35; max-width: 70%; text-shadow: 0 1px 3px rgba(0,0,0,0.3); }
    .post-cover-brand { display: flex; align-items: center; gap: 8px; }
    .post-cover-brand img { width: 28px; height: 28px; border-radius: 6px; }
    .post-cover-brand span { font-size: 0.8rem; font-weight: 700; color: rgba(255,255,255,0.9); }
    @media (max-width: 600px) { .post-cover-card img { height: 220px; } .post-cover-title { font-size: 1rem; max-width: 100%; } .post-cover-content { flex-direction: column; align-items: flex-start; gap: 10px; } }
    .post-tags { display: flex; gap: 10px; flex-wrap: wrap; margin: 10px 0 0; }
    .post-tag-badge { background: rgba(255,255,255,0.15); color: #fff; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; padding: 4px 12px; border-radius: 20px; }
    .post-layout { max-width: 1100px; margin: 0 auto; padding: 64px 24px; display: grid; grid-template-columns: 1fr 300px; gap: 56px; align-items: start; }
    .post-body { max-width: 720px; }
    .post-body h2 { font-size: 1.5rem; color: #1a1a2e; margin: 40px 0 16px; line-height: 1.3; }
    .post-body h3 { font-size: 1.15rem; color: #1a1a2e; margin: 28px 0 12px; }
    .post-body p { color: #444; line-height: 1.8; margin-bottom: 18px; font-size: 1rem; }
    .post-body ul, .post-body ol { padding-left: 24px; margin-bottom: 18px; }
    .post-body li { color: #444; line-height: 1.7; margin-bottom: 6px; font-size: 1rem; }
    .post-body code { background: #f0f4f8; color: #1A5276; padding: 2px 6px; border-radius: 4px; font-size: 0.88em; font-family: "Courier New", monospace; }
    .post-body pre { background: #1a1a2e; color: #e8f4f8; padding: 20px 24px; border-radius: 10px; overflow-x: auto; margin-bottom: 24px; font-size: 0.88rem; line-height: 1.65; }
    .post-body pre code { background: none; color: inherit; padding: 0; }
    .post-body blockquote { border-left: 4px solid #2980B9; margin: 24px 0; padding: 12px 20px; background: #f0f7ff; border-radius: 0 8px 8px 0; color: #444; font-style: italic; }
    .post-body table { width: 100%; border-collapse: collapse; margin: 18px 0 24px; font-size: 0.92rem; }
    .post-body th { background: #1A5276; color: #fff; padding: 10px 14px; text-align: left; font-weight: 600; }
    .post-body td { padding: 10px 14px; border-bottom: 1px solid #e5e7eb; color: #444; }
    .post-body tr:nth-child(even) { background: #f8fafc; }
    .post-body .callout { background: #EAF2F8; border-left: 4px solid #1A5276; border-radius: 0 10px 10px 0; padding: 18px 22px; margin: 24px 0; }
    .post-body .callout strong { color: #1A5276; }
    .post-body .callout p { margin: 0; color: #444; }
    .post-body .callout-warning { background: #FFF3E0; border-left: 4px solid #E67E22; border-radius: 0 10px 10px 0; padding: 18px 22px; margin: 24px 0; }
    .post-body .callout-warning strong { color: #E67E22; }
    .post-body .callout-warning p { margin: 0; color: #444; }
    .post-body .callout-danger { background: #FDEDEC; border-left: 4px solid #C0392B; border-radius: 0 10px 10px 0; padding: 18px 22px; margin: 24px 0; }
    .post-body .callout-danger strong { color: #C0392B; }
    .post-body .callout-danger p { margin: 0; color: #444; }
    .post-body .series-nav { background: #f8fafc; border: 1px solid #e5e7eb; border-radius: 12px; padding: 22px; margin: 32px 0; }
    .post-body .series-nav h4 { font-size: 0.95rem; color: #1a1a2e; margin-bottom: 12px; }
    .post-body .series-nav ol { padding-left: 20px; margin: 0; }
    .post-body .series-nav li { font-size: 0.9rem; margin-bottom: 4px; }
    .post-body .series-nav a { color: #2980B9; text-decoration: none; }
    .post-body .series-nav .current { font-weight: 700; color: #1A5276; }
    .post-body .checklist { list-style: none; padding-left: 0; }
    .post-body .checklist li { padding: 6px 0 6px 28px; position: relative; }
    .post-body .checklist li::before { content: "\2610"; position: absolute; left: 0; color: #1A5276; font-size: 1.1em; }
    .post-body figure { margin: 24px 0; text-align: center; }
    .post-body figure img { max-width: 100%; height: auto; border-radius: 10px; box-shadow: 0 4px 16px rgba(0,0,0,0.08); }
    .post-body figcaption { font-size: 0.85rem; color: #777; margin-top: 8px; font-style: italic; }
    .post-cta-inline { background: #1A5276; color: #fff; border-radius: 12px; padding: 28px 32px; margin: 40px 0; }
    .post-cta-inline h4 { font-size: 1.1rem; margin-bottom: 8px; color: #fff; }
    .post-cta-inline p { font-size: 0.92rem; color: rgba(255,255,255,0.82); margin-bottom: 16px; }
    .post-cta-inline .btn { background: #E67E22; border-color: #E67E22; color: #fff; padding: 10px 20px; border-radius: 6px; text-decoration: none; font-weight: 600; display: inline-block; }
    .post-body .related-posts { margin-top: 48px; }
    .post-body .related-posts h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 20px; color: #1a1a2e; }
    .related-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .related-card { background: #f8fafc; border: 1px solid #e5e7eb; border-radius: 10px; padding: 18px; text-decoration: none; transition: box-shadow 0.15s; display: block; }
    .related-card:hover { box-shadow: 0 4px 16px rgba(26,82,118,0.08); }
    .related-card .rc-cat { font-size: 0.72rem; font-weight: 700; color: #2980B9; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 6px; }
    .related-card h4 { font-size: 0.9rem; color: #1a1a2e; line-height: 1.4; margin: 0; }
    .author-box { display: flex; align-items: flex-start; gap: 16px; border: 1px solid #e5e7eb; border-radius: 12px; padding: 24px; margin-top: 48px; }
    .author-avatar { width: 56px; height: 56px; border-radius: 50%; background: #1A5276; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; font-weight: 800; color: #fff; flex-shrink: 0; }
    .author-info h4 { font-size: 1rem; color: #1a1a2e; margin-bottom: 4px; }
    .author-info p { font-size: 0.88rem; color: #666; line-height: 1.6; margin: 0; }
    .post-sidebar { position: sticky; top: 90px; }
    .sidebar-widget { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 22px; margin-bottom: 20px; }
    .sidebar-widget h3 { font-size: 0.85rem; font-weight: 700; color: #1a1a2e; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 14px; padding-bottom: 10px; border-bottom: 2px solid #EAF2F8; }
    .toc-list { list-style: none; padding: 0; margin: 0; }
    .toc-list li { padding: 6px 0; border-bottom: 1px solid #f5f5f5; }
    .toc-list li:last-child { border-bottom: none; }
    .toc-list a { font-size: 0.87rem; color: #555; text-decoration: none; }
    .sidebar-cta-box { background: #1A5276; color: #fff; border-radius: 12px; padding: 24px 22px; text-align: center; border: none; }
    .sidebar-cta-box h3 { color: #fff; border-bottom-color: rgba(255,255,255,0.15); }
    .sidebar-cta-box p { font-size: 0.85rem; color: rgba(255,255,255,0.8); line-height: 1.6; margin-bottom: 14px; }
    .sidebar-cta-box .btn { background: #E67E22; border-color: #E67E22; font-size: 0.85rem; padding: 10px 16px; }
    @media (max-width: 880px) { .post-layout { grid-template-columns: 1fr; } .post-sidebar { position: static; } .related-grid { grid-template-columns: 1fr; } .post-body table { font-size: 0.82rem; } .post-body th, .post-body td { padding: 8px 10px; } }
  </style>
</head>
<body>
  <nav id="navbar">
    <div class="nav-inner">
      <a href="../index.html" class="nav-logo" aria-label="ReliaDB Home">
        <img src="/images/ReliaDB logo.svg" alt="ReliaDB logo" class="nav-logo-image" width="180" height="42" />
        <span class="nav-logo-text">Relia<span>DB</span></span>
      </a>
      <ul class="nav-links" id="navLinks">
        <li><a href="../index.html">Home</a></li>
        <li><a href="../services.html">Services</a></li>
        <li><a href="../results.html">Results</a></li>
        <li><a href="/tools/explain/">EXPLAIN Analyzer</a></li>
        <li><a href="index.html" class="active">Blog</a></li>
        <li><a href="../about.html">About</a></li>
        <li><a href="../contact.html" class="nav-cta">Book Free Assessment</a></li>
      </ul>
      {% include "nav-search-controls.njk" %}
      <button id="navToggle" class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false"><span></span><span></span><span></span></button>
    </div>
  </nav>

  <section class="post-hero">
    <div class="post-hero-inner">
      <h1>{{ title }}</h1>
      <div class="post-meta-top">
        {% if categories and categories.length %}
          {% for cat in categories %}
            <a class="post-cat-badge" href="/blog/category/{{ cat }}/">{{ cat | replace("-", " ") }}</a>
          {% endfor %}
        {% elif category %}
          <a class="post-cat-badge" href="/blog/category/{{ category }}/">{{ category | replace("-", " ") }}</a>
        {% else %}
          <span class="post-cat-badge">Uncategorized</span>
        {% endif %}
        <span class="post-date-top">{{ page.date.toDateString() }}</span>
        <span class="post-read-top">&middot; {{ read_time or 8 }} min read</span>
        {% if dateModified %}
          <span class="post-updated-badge">Updated {{ dateModified | date("%Y-%m-%d") }}</span>
        {% endif %}
      </div>
      <p class="excerpt">{{ description }}</p>
    </div>
  </section>

  {% if coverImage %}
    {% set coverSrc = coverImage %}
    {% if coverImage.publicURL %}{% set coverSrc = coverImage.publicURL %}
    {% elif coverImage.url %}{% set coverSrc = coverImage.url %}
    {% elif coverImage.path %}{% set coverSrc = coverImage.path %}{% endif %}
    <div class="post-cover-banner">
      <div class="post-cover-card">
        <img src="{{ coverSrc }}" alt="{{ coverImageAlt or title }}" />
        <div class="post-cover-overlay"></div>
        <div class="post-cover-content">
          <span class="post-cover-title">{{ title }}</span>
          <div class="post-cover-brand">
            <img src="/images/ReliaDB-Logo.png" alt="ReliaDB" />
            <span>ReliaDB</span>
          </div>
        </div>
      </div>
    </div>
  {% endif %}

  <div class="post-layout">
    <article class="post-body">
      {{ content | safe }}
      <div class="author-box">
        <div class="author-avatar">{{ (author or "Mughees Ahmed") | truncate(1, true, "") | upper }}</div>
        <div class="author-info">
          <h4>{{ author or "Mughees Ahmed" }} — ReliaDB</h4>
          <p>ReliaDB is a specialist DBA team for PostgreSQL and MySQL performance, high availability, and cloud database optimization. <a href="../about.html" style="color:#2980B9;">More about ReliaDB &rarr;</a></p>
        </div>
      </div>
    </article>

    <aside class="post-sidebar">
      <div class="sidebar-widget sidebar-cta-box">
        <h3>Database Problems?</h3>
        <p>Get actionable advice for your setup in a free assessment call.</p>
        <a href="../contact.html" class="btn">Book Free Call</a>
      </div>
      <div class="sidebar-widget">
        <h3>Latest Posts</h3>
        <ul class="toc-list">
          {% for post in collections.blogPosts %}
            {% if loop.index <= 5 %}
              <li><a href="{{ post.url }}">{{ post.data.title }}</a></li>
            {% endif %}
          {% endfor %}
        </ul>
      </div>
    </aside>
  </div>

  {% include "footer.njk" %}
  <script src="../js/main.js"></script>
</body>
</html>
